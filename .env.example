# Copiá este archivo a ".env" y completá con tus datos de Supabase.
# Estos dos valores son PÚBLICOS (la anon key está pensada para el navegador).
# Tu API key de Claude NO va acá: vive como secreto dentro de Supabase (ver README).

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica

# Opcional: base path para GitHub Pages. Por defecto "/personal_trainer/".
# VITE_BASE=/personal_trainer/
